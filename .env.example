# ─────────────────────────────────────────────────────────────
# INJ Pass Backend Environment
# ─────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Passkey / Auth
RP_ID=localhost
ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
JWT_SECRET=replace-with-a-strong-jwt-secret-min-32-chars

# Admin
ADMIN_API_KEY=replace-with-a-strong-admin-secret

# Database / Cache
DATABASE_URL=postgresql://postgres.xxx:xxx@aws-0-us-east-1.pooler.supabase.com:6543/postgres
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# AI Runtime (REQUIRED for agent chat in production)
ANTHROPIC_API_KEY=replace-with-your-provider-key
ANTHROPIC_BASE_URL=https://yinli.one
AGENT_MODEL_DEFAULT=gpt-5.1

# Optional but recommended for sandbox key encryption isolation
AGENT_WALLET_MASTER_KEY=replace-with-a-strong-random-secret

# DApp image storage (S3-compatible)
SUPABASE_S3_ACCESS_KEY_ID=your-supabase-s3-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-supabase-s3-secret-access-key
SUPABASE_S3_ENDPOINT=https://your-project.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-west-2
SUPABASE_S3_BUCKET=injpass
SUPABASE_PUBLIC_BASE_URL=https://your-project.supabase.co/storage/v1/object/public/injpass

# Pinata JWT (server-side). Used to upload collection images and metadata.
# Obtain a JWT from https://pinata.cloud and set it here.
PINATA_JWT=

# Cat NFT voucher mint signing
CAT_NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
CAT_NFT_VOUCHER_SIGNER_PRIVATE_KEY=
INJECTIVE_EVM_CHAIN_ID=1776
INJECTIVE_EVM_RPC=https://sentry.evm-rpc.injective.network/

# ─────────────────────────────────────────────────────────────
# Chance Worker only
# Run with: pnpm start:chance-worker
# Deploying worker separately? Put only this block plus ADMIN_API_KEY in that service.
# ─────────────────────────────────────────────────────────────
WORKER_RPC_URL=https://sentry.evm-rpc.injective.network/
CHANCE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
WORKER_BACKEND_API_URL=http://localhost:3000
WORKER_CHAIN_ID=injective-mainnet
WORKER_STATIC_CHAIN_ID=1776
WORKER_POLL_INTERVAL_MS=8000
WORKER_BLOCK_CONFIRMATIONS=2
WORKER_MAX_BLOCK_RANGE=1200
WORKER_RECEIPT_FALLBACK_BLOCK_RANGE=60
WORKER_START_BLOCK=0
WORKER_AUTO_CATCH_UP=true
WORKER_AUTO_CATCH_UP_WINDOW=2000
WORKER_MAX_LAG_BEFORE_RESET=500000
WORKER_STATE_FILE=.chance-worker-state.json
