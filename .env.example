# Server Configuration
PORT=3000
NODE_ENV=development

# Passkey Configuration
RP_ID=localhost
ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# JWT Configuration (Session Token)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Admin Dashboard
ADMIN_API_KEY=replace-with-a-strong-admin-secret

# PostgreSQL (Supabase)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres.xxx:xxx@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Redis (Upstash)
# Format: rediss://default:[password]@[host]:[port]
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# Supabase Storage (S3)
SUPABASE_S3_ACCESS_KEY_ID=your-supabase-s3-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-supabase-s3-secret-access-key
SUPABASE_S3_ENDPOINT=https://your-project.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-west-2
SUPABASE_S3_BUCKET=injpass
SUPABASE_PUBLIC_BASE_URL=https://your-project.supabase.co/storage/v1/object/public/injpass

# Chance Chain Worker
# Run with: pnpm start:chance-worker
WORKER_RPC_URL=Injective testnet RPC
CHANCE_CONTRACT_ADDRESS=
WORKER_BACKEND_API_URL=https://your-backend-domain
WORKER_CHAIN_ID=injective
WORKER_POLL_INTERVAL_MS=8000
WORKER_BLOCK_CONFIRMATIONS=2
WORKER_MAX_BLOCK_RANGE=1200
WORKER_RECEIPT_FALLBACK_BLOCK_RANGE=60
WORKER_START_BLOCK=0
# When true, worker will auto-jump near latest if cursor is extremely stale.
WORKER_AUTO_CATCH_UP=true
# Keep this many blocks of recent history when auto catching up.
WORKER_AUTO_CATCH_UP_WINDOW=2000
# If lag exceeds this, state will be reset to latest-window.
WORKER_MAX_LAG_BEFORE_RESET=500000
WORKER_STATE_FILE=.chance-worker-state.json