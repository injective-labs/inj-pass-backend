NODE_ENV=production

# Worker target
CHANCE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
WORKER_BACKEND_API_URL=https://your-backend-domain
ADMIN_API_KEY=replace-with-your-admin-api-key

# Chain
WORKER_RPC_URL=https://sentry.evm-rpc.injective.network/
WORKER_CHAIN_ID=injective-mainnet
WORKER_STATIC_CHAIN_ID=1776

# Polling
WORKER_POLL_INTERVAL_MS=2500
WORKER_BLOCK_CONFIRMATIONS=2
WORKER_MAX_BLOCK_RANGE=1200
WORKER_RECEIPT_FALLBACK_BLOCK_RANGE=60
WORKER_START_BLOCK=0

# Cursor guard
WORKER_AUTO_CATCH_UP=true
WORKER_AUTO_CATCH_UP_WINDOW=2000
WORKER_MAX_LAG_BEFORE_RESET=500000
WORKER_STATE_FILE=.chance-worker-state.json
